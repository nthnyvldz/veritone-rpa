# ─────────────────────────────────────────────
# Veritone RPA – Environment Variables Template
# Copy this file to .env and fill in real values
# Never commit .env to version control
# ─────────────────────────────────────────────

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Runtime mode: "production" | "testing"
# In testing mode the 7pm–7am window is NOT enforced
RUN_MODE=production

# Lookback window for adverts (days)
LOOKBACK_DAYS=30

# Email notifications (Gmail)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Veritone Hire login (optional — falls back to manual login if not set)
VERITONE_USERNAME=your_veritone_username_here
VERITONE_PASSWORD=your_veritone_password_here
